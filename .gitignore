# =============================================================
#  fdtd-sim .gitignore
# =============================================================

# Python version (commit this — it pins the project's Python)
# .python-version  ← intentionally NOT ignored

# -------------------------------------------------------------
#  Virtual environment
# -------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -------------------------------------------------------------
#  Python cache & compiled files
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# -------------------------------------------------------------
#  Distribution / packaging
# -------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST

# -------------------------------------------------------------
#  Testing & coverage
# -------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.cover
.hypothesis/

# -------------------------------------------------------------
#  Jupyter notebooks
# -------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -------------------------------------------------------------
#  Simulation outputs  (regenerate by running examples/)
# -------------------------------------------------------------
assets/*.png
assets/*.gif
assets/*.mp4
assets/*.npy
assets/*.npz

# -------------------------------------------------------------
#  macOS system files
# -------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# -------------------------------------------------------------
#  Editor & IDE
# -------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, etc.)
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# -------------------------------------------------------------
#  Environment variables
# -------------------------------------------------------------
.env
.env.*
!.env.example

# -------------------------------------------------------------
#  Logs & temp files
# -------------------------------------------------------------
*.log
*.tmp
*.bak
tmp/
